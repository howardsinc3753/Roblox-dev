# Roblox / Wally packages (regenerated from wally.lock)
Packages/
ServerPackages/
DevPackages/

# Build output
build/

# Generated voiceover MP3s (regenerated from lines.json via ElevenLabs)
voiceover/out/

# Generated 3D models (large FBX/GLB files from Meshy, regenerable)
assets/models/dragons/*.fbx
assets/models/dragons/*.glb
assets/models/dragons/*.obj
assets/models/dragons/*.usdz

# Large audio source files. Final game audio is uploaded to Roblox via
# Asset Manager and referenced by rbxassetid:// — the local source files
# don't need to be in git. Use Git LFS if you ever need to version them.
assets/audio/*.mp3
assets/audio/*.wav
assets/audio/*.ogg
assets/audio/*.flac

# Roblox place files (built by Rojo, edited in Studio)
*.rbxl
*.rbxlx
# Uncomment below if you want to version-control specific place files:
# !game.rbxlx

# Node modules (if using roblox-ts or npm tools)
node_modules/
package-lock.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets (NEVER commit)
.env
.env.local
*.pem
*.key
secrets.yaml

# Deploy config: contains place + universe IDs (not secret per se, but
# tied to a specific Roblox account — easier to keep out of git than
# require everyone to have the same IDs). Use deploy.config.example.json
# as the template.
deploy.config.json

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Rokit binaries cache (managed by rokit)
.rokit/
