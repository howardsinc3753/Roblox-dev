# !game.rbxlx

# Node modules (if using roblox-ts or npm tools)
node_modules/
package-lock.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets (NEVER commit)
.env
.env.local
*.pem
*.key
secrets.yaml

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Rokit binaries cache (managed by rokit)
.rokit/
